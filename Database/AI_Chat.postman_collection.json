{
  "info": {
    "name": "AI Chat API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "New Conversation",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"message\": \"Hello, who are you?\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://localhost:4000/api/chat/send",
          "protocol": "http",
          "host": ["localhost"],
          "port": "4000",
          "path": ["api", "chat", "send"]
        }
      }
    },
    {
      "name": "Continue Conversation",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"conversation_id\": \"paste-conversation-id-from-previous-response\",\n  \"message\": \"Tell me more about that.\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://localhost:4000/api/chat/send",
          "protocol": "http",
          "host": ["localhost"],
          "port": "4000",
          "path": ["api", "chat", "send"]
        }
      }
    }
  ]
}
